{
  "model": "marketplace.communitypost",
  "pk": 1,
  "fields": {
    "post_type": "Farm Story",
    "is_public": false,
    "title": "Our First Polytunnel Harvest",
    "description": "After two years of planning we finally harvested our first full crop from the new polytunnels this week — basil, tomatoes and salad leaves all looking incredible. We can now supply fresh greens year-round. A huge thank you to everyone who helped with the build last autumn!",
    "created_at": "2026-04-23T23:49:01.354Z"
  }
},
{
  "model": "marketplace.communitypost",
  "pk": 2,
  "fields": {
    "post_type": "Farm Story",
    "is_public": true,
    "title": "Spring Update from the Orchard",
    "description": "Blossom is out across all the apple and pear trees at Ceridwen's Orchard. If the weather holds we're expecting a bumper crop this autumn. Strawberry plants are in flower too — fingers crossed for a warm June!",
    "created_at": "2026-04-23T23:49:01.365Z"
  }
},
{
  "model": "marketplace.communitypost",
  "pk": 3,
  "fields": {
    "post_type": "Recipe",
    "is_public": true,
    "title": "Heritage Carrot & Ginger Soup",
    "description": "Ingredients: 500 g Green Valley heritage carrots, 1 onion, 2 cloves garlic, thumb of fresh ginger, 1 L vegetable stock, 200 ml Sunny Meadow whole milk, salt & pepper.\n\nSweat onion, garlic and ginger in oil for 5 min. Add carrots and stock, simmer 20 min until tender. Blitz smooth, stir in the milk and season. Serves 4.",
    "created_at": "2026-04-23T23:49:01.371Z"
  }
},
{
  "model": "marketplace.communitypost",
  "pk": 4,
  "fields": {
    "post_type": "Recipe",
    "is_public": true,
    "title": "Courgette, Herb & Egg Frittata",
    "description": "Ingredients: 3 courgettes (Green Valley), 6 eggs (Sunny Meadow), handful of fresh basil and parsley (Green Valley), 50 g mature cheddar (Sunny Meadow), salt & pepper.\n\nSlice and fry courgettes until golden. Beat eggs, stir in herbs and cheese. Pour over courgettes in an ovenproof pan. Cook on hob 3 min then finish under a hot grill for 5 min. Serves 3–4.",
    "created_at": "2026-04-23T23:49:01.377Z"
  }
},
{
  "model": "marketplace.communitypost",
  "pk": 5,
  "fields": {
    "post_type": "Farm Story",
    "is_public": false,
    "title": "Winter Cover Crop Update (Internal)",
    "description": "Overwinter rye and vetch across fields 3 and 4 looking healthy. Ploughing back in late April ahead of the brassica beds. Internal record only.",
    "created_at": "2026-04-23T23:49:01.384Z"
  }
},
