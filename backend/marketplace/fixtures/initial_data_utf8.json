{
  "model": "marketplace.communitypost",
  "pk": 3,
  "fields": {
    "post_type": "Recipe",
    "is_public": true,
    "title": "Heritage Carrot & Ginger Soup",
    "description": "Ingredients: 500 g Green Valley heritage carrots, 1 onion, 2 cloves garlic, thumb of fresh ginger, 1 L vegetable stock, 200 ml Sunny Meadow whole milk, salt & pepper.\n\nSweat onion, garlic and ginger in oil for 5 min. Add carrots and stock, simmer 20 min until tender. Blitz smooth, stir in the milk and season. Serves 4.",
